<h1>Productos</h1>

<a href="/carts/{{user.cart}}" style="display: block; margin-bottom: 20px; font-weight: bold;">
    Ver Mi Carrito
</a>

<div>
    {{#each products.docs}}
        <article>
            <h3>{{this.title}}</h3>
            <p>Precio: ${{this.price}}</p>
            <a href="/products/{{this._id}}">Ver Detalles</a>
            <button onclick="addToCart('{{../user.cart}}', '{{this._id}}')">Agregar al Carrito</button>
        </article>
        <hr>
    {{/each}}
</div>

<div style="margin-bottom: 30px;">
    {{#if products.hasPrevPage}}
        <a href="/products?page={{products.prevPage}}&limit={{products.limit}}">Página Anterior</a>
    {{/if}}
    <span>Página {{products.page}} de {{products.totalPages}}</span>
    {{#if products.hasNextPage}}
        <a href="/products?page={{products.nextPage}}&limit={{products.limit}}">Página Siguiente</a>
    {{/if}}
</div>

<hr>

<div style="margin-top: 20px; padding-bottom: 20px;">
    <button onclick="logout()" style="background-color: #dc3545; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer;">
        Cerrar Sesión
    </button>
</div>

<script>
    function addToCart(cartId, productId) {
        // Pequeña validación de seguridad
        if (!cartId) {
            alert('No se encontró el carrito. ¿Iniciaste sesión correctamente?');
            return;
        }

        fetch(`/api/carts/${cartId}/products/${productId}`, {
            method: 'POST',
        })
        .then(response => {
            if (response.ok) {
                alert('¡Producto agregado al carrito exitosamente! 🛒');
            } else {
                alert('Error al agregar el producto. Revisa la consola.');
            }
        })
        .catch(error => console.error('Error:', error));
    }

    // Función de Logout
    function logout() {
        fetch('/api/sessions/logout', {
            method: 'POST'
        }).then(result => {
            if (result.status === 200) {
                window.location.replace('/login');
            }
        });
    }
</script>