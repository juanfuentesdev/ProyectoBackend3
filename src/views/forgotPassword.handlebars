<div style="max-width: 400px; margin: 50px auto; padding: 20px; border: 1px solid #ccc; border-radius: 5px;">
    <h2>Recuperar Contraseña</h2>
    <p>Ingresa tu correo electrónico y te enviaremos un enlace para restablecer tu contraseña.</p>
    
    <form id="forgotForm">
        <div style="margin-bottom: 15px;">
            <label>Email:</label>
            <input type="email" id="email" required style="width: 100%; padding: 8px;">
        </div>
        <button type="submit" style="width: 100%; padding: 10px; background-color: #007bff; color: white; border: none; cursor: pointer;">Enviar Correo</button>
    </form>
    <a href="/login" style="display: block; margin-top: 10px; text-align: center;">Volver al Login</a>
</div>

<script>
    const form = document.getElementById('forgotForm');

    form.addEventListener('submit', e => {
        e.preventDefault();
        const email = document.getElementById('email').value;

        fetch('/api/sessions/forgot-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
        })
        .then(res => res.json())
        .then(data => {
            if(data.status === 'success') {
                alert('Correo enviado. Revisa tu bandeja de entrada (y spam).');
            } else {
                alert(data.error);
            }
        });
    });
</script>